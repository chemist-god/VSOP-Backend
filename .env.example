NODE_ENV=development
PORT=3001
# Defaults to true when NODE_ENV !== production; set explicitly on Render if needed
ENABLE_SWAGGER=true

DATABASE_URL=postgresql://USER:PASSWORD@HOST/vsop?sslmode=require
DIRECT_DATABASE_URL=postgresql://USER:PASSWORD@HOST/vsop?sslmode=require

VSOP_SERVICE_KEY=replace_with_random_hex_32

JWT_SECRET=replace_with_random_hex_32
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=replace_with_random_hex_32
JWT_REFRESH_EXPIRES_IN=7d

BCRYPT_ROUNDS=12

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

RESEND_API_KEY=
RESEND_FROM_EMAIL=VeriTrack Support <support@veritrack.cloud>

INTAKE_RATE_LIMIT_TTL=3600
INTAKE_RATE_LIMIT_MAX=10

FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
INVITE_EXPIRY_HOURS=48

